// AgentBeats registration manifest for VeritasX
// See: https://docs.agentbeats.dev/manifest/
{
  manifest_version: "0.1.0",

  metadata: {
    name: "VeritasX",
    description: "RAG agent over US Treasury bulletins (1939-2025). Answers fiscal/financial questions with exact arithmetic grounded in local corpus.",
  },

  // Only secrets go in config_schema; non-sensitive values are static env.
  config_schema: {
    type: "object",
    properties: {
      google_api_key: {
        type: "string",
        secret: true,
        description: "Gemini AI Studio API Key",
      },
      google_api_key_2: {
        type: "string",
        secret: true,
        description: "Backup Gemini API Key 2",
      },
      google_api_key_3: {
        type: "string",
        secret: true,
        description: "Backup Gemini API Key 3",
      },
      langsmith_api_key: {
        type: "string",
        secret: true,
        description: "LangSmith tracing API key",
      },
    },
    required: ["google_api_key"],
    additionalProperties: false,
  },

  program: {
    image: "ghcr.io/mdadopoulos/veritasx:latest",
    entrypoint: ["python", "-m", "src.server"],
    env: {
      // Secrets sourced from config
      GOOGLE_API_KEY: "${config.google_api_key}",
      GOOGLE_API_KEY_2: "${config.google_api_key_2}",
      GOOGLE_API_KEY_3: "${config.google_api_key_3}",
      LANGSMITH_API_KEY: "${config.langsmith_api_key}",

      // Static configuration
      MODEL_ID: "gemini-3-flash-preview",
      ORCH_MODEL_ID: "gemini-3.1-pro-preview",
      LANGSMITH_TRACING: "true",
      LANGCHAIN_TRACING_V2: "true",
      LANGSMITH_ENDPOINT: "https://eu.api.smith.langchain.com",
      LANGSMITH_PROJECT: "default",
      CORPUS_SOURCE: "local",
      CORPUS_DIR: "/home/agent/corpus/transformed",
      AGENT_TIMEOUT_SECONDS: "3000",
      SKILLS_DIR: "/home/agent/agentspace/skills",
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },
  exports: { a2a: "a2a" },
}
