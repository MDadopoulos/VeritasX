# ============================================================
# AgentBeats OfficeQA Finance Agent — Environment Variables
# Copy to .env and fill in values before running.
# ============================================================

# Model selection (default: claude-sonnet-4-6)
# Supported prefixes: "gemini-" and "claude-"
# Examples: gemini-2.0-flash, claude-sonnet-4-6
MODEL_ID=claude-sonnet-4-6

# Google Cloud project ID (REQUIRED)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud location.
# For Gemini via google-genai SDK: use "global" or "us-central1"
# For Claude on Vertex AI Model Garden: use a region where Claude is available,
#   e.g. "us-east5" or "europe-west1" (NOT "global").
# NOTE: If you switch MODEL_ID between gemini-* and claude-*, you may need to
#       update this value accordingly. See RESEARCH.md Pitfall #1.
GOOGLE_CLOUD_LOCATION=global

# Required for ChatGoogleGenerativeAI (Gemini) on Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true

# Required for ChatAnthropicVertex (Claude) on Vertex AI Model Garden.
# Point to your service-account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Corpus source mode: "local" (default) fails hard if corpus files are missing.
# Future modes (e.g. "remote") are out of scope for Phase 1.
CORPUS_SOURCE=local

# Path to the directory containing transformed corpus files (*.txt).
# Default resolves relative to the workspace directory.
CORPUS_DIR=../corpus/transformed

# Paths to the benchmark CSV files.
CSV_FULL_PATH=../officeqa_full.csv
CSV_PRO_PATH=../officeqa_pro.csv
